# RailMind Environment Variables
# Copy this to .env and fill in your values.

# LLM Provider — Gemini (tried first, optional)
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
RAILMIND_GEMINI_MODEL=gemini-2.0-flash

# LLM Provider — OpenAI (fallback if Gemini unset, optional)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
RAILMIND_LLM_MODEL=gpt-4o-mini

# Database (defaults to local SQLite file if unset)
# For PostgreSQL: postgresql+psycopg2://<user>:<password>@<host>:5432/<db>
# For Supabase: postgresql+psycopg2://<user>:<password>@<host>:6543/<db>?sslmode=require
DATABASE_URL=
